# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Hashim Qureshi

# Contact (Resend)
# Get key: https://resend.com/api-keys
RESEND_API_KEY=
CONTACT_TO_EMAIL=ihashimaq@gmail.com
# Use onboarding@resend.dev for testing, or your verified domain sender
CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"

# Google reCAPTCHA v3 (Admin Login)
# 1. Create keys: https://www.google.com/recaptcha/admin
# 2. Choose reCAPTCHA v3
# 3. Add domains: localhost + your production domain
# 4. Paste Site Key (public) and Secret Key (server-only)
# Site key is safe in the browser; Secret key must NEVER be exposed to the client
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Admin login rate limiting (IP-based)
# Defaults: 5 failed attempts / 15-minute window / 15-minute block
MAX_LOGIN_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
# Block duration in minutes after the limit is exceeded
LOGIN_BLOCK_DURATION=15

# Optional: Upstash Redis for production rate limiting (shared across instances)
# https://console.upstash.com → Redis → REST API
# Strongly recommended in production so limits are shared across instances
# If unset, an in-memory fallback is used (fine for local / single instance)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Contact form rate limiting (IP-based)
# Defaults: 8 submissions / 10-minute window / 30-minute block
MAX_CONTACT_ATTEMPTS=8
CONTACT_WINDOW_MINUTES=10
CONTACT_BLOCK_DURATION=30

# Supabase (Auth + project URL)
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role is server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

# Admin seed (scripts/seed-admin.ts) — never commit real password
ADMIN_EMAIL=ihashimaq@gmail.com
ADMIN_PASSWORD=

# Database (Prisma → Supabase PostgreSQL)
# DATABASE_URL = Transaction pooler (port 6543) for the app runtime
# DIRECT_URL   = Direct / session connection for Prisma CLI migrations
#
# Example (replace password + project ref + region):
# DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres"
DATABASE_URL=
DIRECT_URL=
